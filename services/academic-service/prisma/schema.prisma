generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SemesterStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Semester {
  id           Int            @id @default(autoincrement())
  name         String
  academicYear String
  startDate    DateTime
  endDate      DateTime
  status       SemesterStatus
  userId       Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}
