generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SemesterStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum SubjectStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum AssignmentStatus {
  PENDING
  SUBMITTED
  GRADED
  OVERDUE
}

enum AssignmentPriority {
  LOW
  MEDIUM
  HIGH
}

model Semester {
  id           Int            @id @default(autoincrement())
  name         String
  academicYear String
  startDate    DateTime
  endDate      DateTime
  status       SemesterStatus
  userId       Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  subjects Subject[]
}

model Subject {
  id             Int           @id @default(autoincrement())
  code           String
  name           String
  credits        Int
  lecturer       String?       // Maps to professorName
  professorEmail String?
  description    String?
  currentGrade   String?
  progress       Int           @default(0)
  status         SubjectStatus
  color          String        @default("blue")
  room           String?
  schedule       String?
  targetGrade    String        @default("A")
  semesterId     Int
  userId         Int

  semester    Semester     @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  assignments Assignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assignment {
  id          Int                @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime
  priority    AssignmentPriority @default(MEDIUM)
  status      AssignmentStatus   @default(PENDING)
  progress    Int                @default(0)
  marks       Float?
  maxMarks    Float              @default(100)
  weight      Float              @default(0)
  isGroup     Boolean            @default(false)
  subjectId   Int
  userId      Int

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
